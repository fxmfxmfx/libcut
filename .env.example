# SQLite database file path. Inside Docker, use /app/db/custom.db.
DATABASE_URL=file:/app/db/custom.db

# Demo mode: true = serve built-in sample data (no real TikTok access).
# Set to false on your server with a working SOCKS5 proxy.
DEMO_MODE=true

# SOCKS5 proxy for yt-dlp (all TikTok access goes through this).
# Format: socks5://user:pass@host:port
# Can also be set at runtime in the Settings panel.
TIKTOK_PROXY=socks5://127.0.0.1:1080

# Video cache lifetime in minutes (temp files auto-deleted after this).
TIKTOK_CACHE_TTL_MIN=10

# ! IMPORTANT
# Where user data (subscriptions, favorites, seen-state) is stored.
#   local   = SQLite database on the server (default). Single-user / trusted network.
#             Warning: anyone who can access the web page can view and delete ALL data.
#   client  = Browser localStorage. Nothing persisted server-side. For public instances.
#             Each user's data stays in their own browser.
DATA_MODE=client
